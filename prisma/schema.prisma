generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Booking {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingType           BookingType            @default(PERSONAL)
  fullName              String
  email                 String
  phone                 String
  pickupLocation        String
  pickupLatitude        Float?
  pickupLongitude       Float?
  pickupPlaceId         String?
  pickupLocationSource  BookingLocationSource?
  dropoffLocation       String
  dropoffLatitude       Float?
  dropoffLongitude      Float?
  dropoffPlaceId        String?
  dropoffLocationSource BookingLocationSource?
  pickupDateTime        DateTime               @db.Timestamp(6)
  carType               CarType                @default(SEDAN)
  specialInstructions   String?
  internalNotes         String?
  status                BookingStatus          @default(NEW)
  paymentStatus         PaymentStatus          @default(UNPAID)
  assignmentType        AssignmentType?
  createdAt             DateTime               @default(now()) @db.Timestamp(6)
  updatedAt             DateTime               @default(now()) @updatedAt @db.Timestamp(6)
  bookingReference      String                 @unique
  driverId              String?
  vendorId              String?
  vehicleId             String?
  assignedAt            DateTime?
  confirmedAt           DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  archivedAt            DateTime?
  cancelReason          String?
  fareAmount            Decimal?               @db.Decimal(10, 2)
  commissionAmount      Decimal?               @db.Decimal(10, 2)
  payoutAmount          Decimal?               @db.Decimal(10, 2)
  netEarningAmount      Decimal?               @db.Decimal(10, 2)
  driverEarning         Decimal?               @db.Decimal(10, 2)
  paymentReceivedAt     DateTime?
  manualVendorName      String?
  manualDriverName      String?
  manualDriverPhone     String?
  manualVehicleDetails  String?
  driver                Driver?                @relation(fields: [driverId], references: [id])
  vendor                Vendor?                @relation(fields: [vendorId], references: [id])
  vehicle               Vehicle?               @relation(fields: [vehicleId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([driverId])
  @@index([vendorId])
  @@index([vehicleId])
  @@index([paymentStatus])
  @@index([archivedAt])
}

model Driver {
  id                 String             @id @default(uuid())
  name               String
  phone              String
  email              String?
  vehicleType        CarType
  vehicleNumber      String
  isActive           Boolean            @default(true)
  driverType         DriverType
  availabilityStatus DriverAvailability @default(AVAILABLE)
  companyName        String?
  licenseInfo        String?
  notes              String?
  vendorId           String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @default(now()) @updatedAt
  driverCode         String?            @unique
  bookings           Booking[]
  vendor             Vendor?            @relation(fields: [vendorId], references: [id])
  vehicles           Vehicle[]

  @@index([isActive])
  @@index([driverType])
  @@index([availabilityStatus])
  @@index([vendorId])
}

model Vendor {
  id            String    @id @default(uuid())
  name          String
  phone         String
  email         String?
  contactPerson String?
  notes         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  drivers       Driver[]
  vehicles      Vehicle[]
  bookings      Booking[]

  @@index([isActive])
}

model Vehicle {
  id            String        @id @default(uuid())
  plateNumber   String        @unique
  model         String
  vehicleType   CarType
  ownershipType OwnershipType
  driverId      String?
  vendorId      String?
  companyName   String?
  status        VehicleStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  driver        Driver?       @relation(fields: [driverId], references: [id])
  vendor        Vendor?       @relation(fields: [vendorId], references: [id])
  bookings      Booking[]

  @@index([driverId])
  @@index([vendorId])
  @@index([status])
}

enum BookingStatus {
  NEW
  CONFIRMED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DriverType {
  OWN
  THIRD_PARTY
  VENDOR
}

enum DriverAvailability {
  AVAILABLE
  BUSY
  OFFLINE
}

enum CarType {
  SEDAN
  SUV
  VAN
  LUXURY
}

enum BookingType {
  PERSONAL
  BUSINESS
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum AssignmentType {
  OWN_DRIVER
  OUTSOURCED_DRIVER
  MANUAL_OUTSOURCED
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  BUSY
}

enum OwnershipType {
  OWN
  THIRD_PARTY
}

enum BookingLocationSource {
  MANUAL
  CURRENT_LOCATION
}
