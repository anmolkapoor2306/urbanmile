generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Booking {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicBookingId       String                 @unique
  bookingType           BookingType            @default(PERSONAL)
  fullName              String
  email                 String
  phone                 String
  pickupLocation        String
  pickupLatitude        Float?
  pickupLongitude       Float?
  pickupPlaceId         String?
  pickupLocationSource  BookingLocationSource?
  dropoffLocation       String
  dropoffLatitude       Float?
  dropoffLongitude      Float?
  dropoffPlaceId        String?
  dropoffLocationSource BookingLocationSource?
  pickupDateTime        DateTime               @db.Timestamp(6)
  carType               CarType                @default(SEDAN)
  specialInstructions   String?
  internalNotes         String?
  status                BookingStatus          @default(NEEDS_ASSIGNMENT)
  paymentStatus         PaymentStatus          @default(UNPAID)
  assignmentType        AssignmentType?
  createdAt             DateTime               @default(now()) @db.Timestamp(6)
  updatedAt             DateTime               @default(now()) @updatedAt @db.Timestamp(6)
  bookingReference      String                 @unique
  roundTripGroupId      String?
  parentPublicBookingId String?
  customerId            String?                @db.Uuid
  driverId              String?
  vendorId              String?
  vehicleId             String?
  assignedAt            DateTime?
  confirmedAt           DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  cancelReason          String?
  fareAmount            Decimal?               @db.Decimal(10, 2)
  commissionAmount      Decimal?               @db.Decimal(10, 2)
  payoutAmount          Decimal?               @db.Decimal(10, 2)
  netEarningAmount      Decimal?               @db.Decimal(10, 2)
  driverEarning         Decimal?               @db.Decimal(10, 2)
  paymentReceivedAt     DateTime?
  manualVendorName      String?
  manualDriverName      String?
  manualDriverPhone     String?
  manualVehicleDetails  String?
  driver                Driver?                @relation(fields: [driverId], references: [id])
  customer              Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  vendor                Vendor?                @relation(fields: [vendorId], references: [id])
  vehicle               Vehicle?               @relation(fields: [vehicleId], references: [id])

  @@index([publicBookingId])
  @@index([customerId])
  @@index([roundTripGroupId])
  @@index([status])
  @@index([createdAt])
  @@index([driverId])
  @@index([vendorId])
  @@index([vehicleId])
  @@index([paymentStatus])
}

model Customer {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId       String             @unique
  name           String
  fullName       String             @default("")
  phone          String?            @unique
  email          String?            @unique
  phoneVerified  Boolean            @default(false)
  emailVerified  Boolean            @default(false)
  dob            DateTime?          @db.Date
  gender         CustomerGender?
  authProvider   CustomerAuthProvider?
  passwordHash   String?
  googleId       String?            @unique
  role           CustomerRole       @default(CUSTOMER)
  supabaseUserId String?            @unique
  createdAt      DateTime           @default(now()) @db.Timestamp(6)
  updatedAt      DateTime           @default(now()) @updatedAt @db.Timestamp(6)
  bookings       Booking[]
  sessions       CustomerSession[]

  @@index([publicId])
  @@index([phone])
  @@index([email])
  @@index([googleId])
  @@index([supabaseUserId])
}

model CustomerSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String  @db.Uuid
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime @db.Timestamp(6)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([token])
  @@index([expiresAt])
}

model CustomerOtpVerification {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone       String
  codeHash    String
  token       String?   @unique
  ipAddress   String?
  attempts    Int       @default(0)
  verifiedAt  DateTime?
  expiresAt   DateTime  @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)

  @@index([phone])
  @@index([ipAddress])
  @@index([createdAt])
  @@index([expiresAt])
}

model RateLimitEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action    String
  phone     String?
  ipAddress String?
  createdAt DateTime @default(now()) @db.Timestamp(6)

  @@index([action, phone, createdAt])
  @@index([action, ipAddress, createdAt])
}

model Driver {
  id                 String             @id @default(uuid())
  name               String
  phone              String
  email              String?
  vehicleType        CarType
  vehicleNumber      String
  isActive           Boolean            @default(true)
  driverType         DriverType
  availabilityStatus DriverAvailability @default(AVAILABLE)
  companyName        String?
  licenseInfo        String?
  notes              String?
  vendorId           String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @default(now()) @updatedAt
  driverCode         String?            @unique
  bookings           Booking[]
  vendor             Vendor?            @relation(fields: [vendorId], references: [id])
  vehicles           Vehicle[]

  @@index([isActive])
  @@index([driverType])
  @@index([availabilityStatus])
  @@index([vendorId])
}

model Vendor {
  id            String    @id @default(uuid())
  name          String
  phone         String
  email         String?
  contactPerson String?
  notes         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  drivers       Driver[]
  vehicles      Vehicle[]
  bookings      Booking[]

  @@index([isActive])
}

model Vehicle {
  id            String        @id @default(uuid())
  plateNumber   String        @unique
  model         String
  vehicleType   CarType
  ownershipType OwnershipType
  driverId      String?
  vendorId      String?
  companyName   String?
  status        VehicleStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  driver        Driver?       @relation(fields: [driverId], references: [id])
  vendor        Vendor?       @relation(fields: [vendorId], references: [id])
  bookings      Booking[]

  @@index([driverId])
  @@index([vendorId])
  @@index([status])
}

model OutstationRoute {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  originCity         String
  originState        String?
  destinationCity    String
  destinationState   String?
  originAliases      String[] @default([])
  destinationAliases String[] @default([])
  sedanFare          Decimal  @db.Decimal(10, 2)
  suvMarkup          Decimal  @default(1000) @db.Decimal(10, 2)
  estimatedKm        Decimal? @db.Decimal(8, 2)
  suggestedFare      Decimal? @db.Decimal(10, 2)
  isActive           Boolean  @default(true)
  isBidirectional    Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now()) @db.Timestamp(6)
  updatedAt          DateTime @default(now()) @updatedAt @db.Timestamp(6)

  @@unique([originCity, destinationCity])
  @@index([originCity])
  @@index([destinationCity])
  @@index([isActive])
}

model TripOverride {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromCity             String
  toCity               String
  normalizedFromCity   String
  normalizedToCity     String
  sedanPrice           Decimal  @db.Decimal(10, 2)
  milesXlMarkup        Decimal  @default(0) @db.Decimal(10, 2)
  milesXlMarkupType    String   @default("percentage")
  reverseRoute         Boolean  @default(true)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now()) @db.Timestamp(6)
  updatedAt            DateTime @default(now()) @updatedAt @db.Timestamp(6)

  @@index([normalizedFromCity])
  @@index([normalizedToCity])
  @@index([active])
}

model OperationalZone {
  id                  String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  city                String
  status              OperationalZoneStatus    @default(ENABLED)
  serviceRadiusKm     Int                      @default(25) @map("service_radius_km")
  airportEnabled      Boolean                  @default(true) @map("airport_enabled")
  outstationEnabled   Boolean                  @default(true) @map("outstation_enabled")
  autoDispatchEnabled Boolean                  @default(true) @map("auto_dispatch_enabled")
  enabledVehicleTypes OperationalVehicleType[] @default([SEDAN]) @map("enabled_vehicle_types")
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([city])
  @@index([status])
}

enum BookingStatus {
  NEEDS_ASSIGNMENT
  ASSIGNED
  ACTIVE
  COMPLETE
  CANCELLED
}

enum DriverType {
  OWN
  THIRD_PARTY
  VENDOR
}

enum DriverAvailability {
  AVAILABLE
  BUSY
  OFFLINE
}

enum CarType {
  SEDAN
  SUV
  VAN
  LUXURY
}

enum BookingType {
  PERSONAL
  BUSINESS
}

enum PaymentStatus {
  UNPAID
  PAID
  PENDING
  REFUNDED
  PARTIAL
}

enum CustomerGender {
  MALE
  FEMALE
  NON_BINARY
  OTHER
  PREFER_NOT_TO_SAY
}

enum CustomerAuthProvider {
  MANUAL
  GOOGLE
  PHONE_GUEST
}

enum CustomerRole {
  CUSTOMER
}

enum AssignmentType {
  OWN_DRIVER
  OUTSOURCED_DRIVER
  MANUAL_OUTSOURCED
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  BUSY
}

enum OwnershipType {
  OWN
  THIRD_PARTY
}

enum BookingLocationSource {
  MANUAL
  AUTOCOMPLETE
  MANUAL_PIN
  CURRENT_LOCATION
}

enum OperationalZoneStatus {
  ENABLED
  LIMITED
  DISABLED
}

enum OperationalVehicleType {
  SEDAN
  SUV
  PREMIUM
}

model AdminUser {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  email         String    @unique
  username      String    @unique
  passwordHash  String
  role          AdminRole @default(VIEWER)
  status        AdminUserStatus @default(ACTIVE)
  phone         String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime? @db.Timestamp(6)
  createdAt     DateTime  @default(now()) @db.Timestamp(6)
  updatedAt     DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  sessions      AdminSession[]

  @@index([role])
  @@index([isActive])
}

model AdminSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  role      AdminRole
  token     String    @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime  @db.Timestamp(6)
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model AuditLog {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminUserId   String    @db.Uuid
  action        String
  entityType    String
  entityId      String?
  oldValue      String?   @db.Text
  newValue      String?   @db.Text
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now()) @db.Timestamp(6)

  @@index([adminUserId])
  @@index([entityType])
  @@index([createdAt])
}

enum AdminRole {
  OWNER
  MANAGER
  DISPATCHER
  FINANCE
  VIEWER
}

enum AdminUserStatus {
  PENDING
  ACTIVE
  INACTIVE
}
